# Example .env file for MOT API authentication
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
SCOPE=https://tapi.dvsa.gov.uk/.default
API_KEY=your-api-key
ACCESS_TOKEN=your-access-token
TEST_CLIENT_URL=https://documentation.history.mot.api.gov.uk/
USER_AGENT=Mozilla/5.0 (Macintosh; Intel Mac OS X 10.15; rv:142.0) Gecko/20100101 Firefox/142.0
ACCEPT=text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8
ACCEPT_LANGUAGE=en-GB,en;q=0.5
CONNECTION=keep-alive
UPGRADE_INSECURE_REQUESTS=1
SEC_FETCH_DEST=document
SEC_FETCH_MODE=navigate
SEC_FETCH_SITE=same-site
SEC_FETCH_USER=?1
